{
  "ci": {
    "collect": {
      "url": ["http://localhost:3003/login"],
      "startServerCommand": "bun server.ts",
      "startServerReadyPattern": "Listening on",
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
