{
  "name": "fastcom-docker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=24.0.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "puppeteer",
    "esbuild",
    "sharp",
    "@biomejs/biome"
  ],
  "scripts": {
    "dev": "bun server.ts",
    "build": "bunx drizzle-kit generate && next build && tsup server.ts --format esm --out-dir dist --target node24 --external next --external ws --external bun:sqlite --external drizzle-orm --external execa --external node-cron --external zod --no-splitting",
    "start": "NODE_ENV=production bun dist/server.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "nodemailer": "^6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/bun": "^1.3.12",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
