{
  "name": "speedtest-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=24.0.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "puppeteer",
    "esbuild",
    "sharp",
    "@biomejs/biome"
  ],
  "scripts": {
    "dev": "bun server.ts",
    "build": "bunx drizzle-kit generate && bun scripts/fetch-releases.ts && bun scripts/build-email-templates.ts && next build",
    "build:email": "bun scripts/build-email-templates.ts",
    "releases:fetch": "bun scripts/fetch-releases.ts",
    "start": "NODE_ENV=production bun server.ts",
    "prelint": "next typegen",
    "lint": "bun tsc && bun biome:check && bun biome:format",
    "tsc": "tsc --noEmit --pretty",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write .",
    "biome:format:write": "biome format --write .",
    "biome:format": "biome format .",
    "biome:write": "biome check --write . && biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:a11y": "bunx @axe-core/cli http://localhost:3003 --tags wcag2a,wcag2aa,wcag21a,wcag21aa",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "better-auth": "^1.6.14",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/bun": "^1.3.14",
    "@types/mjml": "^5.0.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "lucide-react": "^1.17.0",
    "mjml": "^5.3.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "radix-ui": "^1.4.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
